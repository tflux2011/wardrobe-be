# Backend
ANTHROPIC_API_KEY=your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Primary model (optional)
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview
# Optional comma-separated fallback order
GEMINI_IMAGE_MODELS=gemini-3.1-flash-image-preview,gemini-2.5-flash-image,gemini-3-pro-image-preview
# Used for full garment reconstruction from uploaded crops
OPENWEATHER_API_KEY=your_openweather_api_key_here
# Required for Firebase ID token verification on protected API routes
FIREBASE_WEB_API_KEY=your_firebase_web_api_key_here
PORT=3002
# Restrict CORS in production (e.g. your frontend domain)
ALLOWED_ORIGIN=*
# Optional global API rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
# Optional tighter rate limiting for AI stylist endpoint
STYLIST_RATE_LIMIT_WINDOW_MS=60000
STYLIST_RATE_LIMIT_MAX_REQUESTS=25
